# Copy to .env (kept out of git) for local Docker / non-compose runs.
# In Railway, set these in the service's Variables tab.

# Server port — Railway injects PORT automatically; defaults to 8080.
PORT=8080

# JDBC URL — must be the JDBC form: jdbc:postgresql://host:port/db
# In Railway, reference the Postgres service's variables, e.g.:
#   jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/pomodoro
SPRING_DATASOURCE_USERNAME=pomodoro
SPRING_DATASOURCE_PASSWORD=pomodoro

# Comma-separated origins allowed to call the API. Add your Vercel URL in prod.
# Example: CORS_ORIGINS=https://pomo-app.vercel.app,https://www.your-domain.com
CORS_ORIGINS=http://localhost:3000

# Optional: log generated SQL.
JPA_SHOW_SQL=false
